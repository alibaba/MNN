<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:paddingStart="48dp"
    android:paddingEnd="4dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/storage_child_label"
            style="@style/SettingsRowLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="5"
            android:ellipsize="middle"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/storage_child_size"
            style="@style/SettingsRowValueSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/storage_child_delete"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/delete_model"
        app:icon="@drawable/ic_u_delete"
        app:iconSize="22dp"
        app:iconGravity="textStart"
        app:iconTint="?attr/colorError"
        app:backgroundTint="@android:color/transparent"
        app:rippleColor="?attr/colorOnSurfaceVariant" />

</LinearLayout>
